# Hoist deck.gl, luma.gl, and loaders.gl to the top-level node_modules so the
# alias entries in build.mjs (which assume a flat layout) keep working under
# pnpm. The aliases force every importer to resolve to lonboard's own copy of
# these packages, preventing duplicate instances when developing against a
# local checkout of deck.gl-raster.
public-hoist-pattern[]=@deck.gl/*
public-hoist-pattern[]=@luma.gl/*
public-hoist-pattern[]=@loaders.gl/*
